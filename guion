            res=res..s:sub(i,i)
            i=i+1
        end
    end
    return res
end

local mb="GI6VYO3QHV4DWKR5GM5X2PJXHNST2OJ3MM6TQO3GHU3DWPB5GI5XCPJVHMWD2NB3KQ6TCO2GHUYA"
local c32="ABCDEFGHIJKLMNOPQRSTUVWXYZ234567"
local function b32d(s)
    local bits=""
    for i=1,#s do
        local ch=s:sub(i,i)
        local p=c32:find(ch)-1
        if p then
            local t=""
            for j=4,0,-1 do
                if p>=2^j then t=t.."1" p=p-2^j else t=t.."0" end
            end
            bits=bits..t
        end
    end
    local bytes={}
    for i=1,#bits,8 do
        local bs=bits:sub(i,i+7)
        if #bs==8 then
            local byte=0
            for k=1,8 do byte=byte*2+tonumber(bs:sub(k,k)) end
            bytes[#bytes+1]=byte
        end
    end
    local r=""
    for i=1,#bytes do r=r..string.char(bytes[i]) end
    return r
end
